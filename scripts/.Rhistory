install.packages("writexl")
library(umx)
library(readxl)
library(dplyr)
library(stringr)
library(writexl)
# ---------------------------------------------------------
# Load data
# ---------------------------------------------------------
twinData <- read_excel("C:/Users/busat/Desktop/PP/prac_proj/data/nsp_balance_with_HCP_info_zscores_wide_all_FC.xlsx")
# ---------------------------------------------------------
# Ensure numeric for all FC variables
# ---------------------------------------------------------
fc_cols <- grep("^FC_.*_T[12]$", names(twinData), value = TRUE)
twinData[fc_cols] <- lapply(twinData[fc_cols], function(x) as.numeric(trimws(x)))
# ---------------------------------------------------------
# Split by zygosity
# ---------------------------------------------------------
dz <- subset(twinData, zyg == "DZ")
mz <- subset(twinData, zyg == "MZ")
# ---------------------------------------------------------
# Extract phenotype names (e.g., FC_rs, FC_task1, ...)
# ---------------------------------------------------------
phenotypes <- unique(str_replace(fc_cols, "_T[12]$", ""))
# ---------------------------------------------------------
# Function to run ACE and extract heritability
# ---------------------------------------------------------
run_ace_h2 <- function(pheno) {
message("Running ACE for: ", pheno)
mod <- try(umxACE(
selDVs = pheno,
sep    = "_T",
dzData = dz,
mzData = mz
), silent = TRUE)
if (inherits(mod, "try-error")) {
warning("ACE failed for ", pheno)
return(data.frame(
phenotype = pheno,
a2 = NA, c2 = NA, e2 = NA, h2 = NA
))
}
# Extract standardized variance components
est <- umxSummary(mod, returnStd = TRUE)
a2 <- est$std$A[1,1]
c2 <- est$std$C[1,1]
e2 <- est$std$E[1,1]
h2 <- a2 / (a2 + c2 + e2)
data.frame(
phenotype = pheno,
a2 = a2,
c2 = c2,
e2 = e2,
h2 = h2
)
}
# ---------------------------------------------------------
# Run ACE for all phenotypes
# ---------------------------------------------------------
results_list <- lapply(phenotypes, run_ace_h2)
require(umx)
library(readxl)
library(stringr)
# ------------------------------
# Load data
# ------------------------------
twinData <- read_excel("C:/Users/busat/Desktop/PP/prac_proj/data/nsp_balance_with_HCP_info_zscores_wide_all_FC.xlsx")
# Identify all FC variables (e.g., FC_rs_T1, FC_rs_T2, ...)
fc_cols <- grep("^FC_.*_T[12]$", names(twinData), value = TRUE)
# Extract base phenotype names (FC_xxx)
phenotypes <- unique(str_replace(fc_cols, "_T[12]$", ""))
# Ensure numeric
twinData[fc_cols] <- lapply(twinData[fc_cols], function(x) as.numeric(trimws(x)))
# Subset by zygosity
dz <- subset(twinData, zyg == "DZ")
mz <- subset(twinData, zyg == "MZ")
# ------------------------------
# Loop over phenotypes
# ------------------------------
for (pheno in phenotypes) {
cat("\n=====================================\n")
cat("Running ACE for:", pheno, "\n")
cat("=====================================\n\n")
# ------------------------------
# ACE model
# ------------------------------
mod_ace <- try(umxACE(
selDVs = pheno,
sep    = "_T",
dzData = dz,
mzData = mz
), silent = TRUE)
if (inherits(mod_ace, "try-error")) {
cat("ACE model failed for", pheno, "\n")
next
}
# AE (drop C)
mod_ae <- umxModify(mod_ace, update = "c_r1c1", name = paste0(pheno, "_AE"))
# CE (drop A)
mod_ce <- umxModify(mod_ace, update = "a_r1c1", name = paste0(pheno, "_CE"))
# E (drop A and C)
mod_e <- umxModify(mod_ae, update = "a_r1c1", name = paste0(pheno, "_E"))
# ------------------------------
# Summaries (same as your script)
# ------------------------------
cat("\n--- Summary ACE ---\n")
print(summary(mod_ace))
cat("\n--- Summary AE ---\n")
print(summary(mod_ae))
cat("\n--- Summary CE ---\n")
print(summary(mod_ce))
cat("\n--- Summary E ---\n")
print(summary(mod_e))
# ------------------------------
# Compare ACE vs AE vs CE vs E
# ------------------------------
models_final <- list(mod_ace, mod_ae, mod_ce, mod_e)
cat("\n--- Model comparison ---\n")
print(umxCompare(models_final))
}
View(models_final)
warning()
