digraph G {
	label="ADE";
	splines = "FALSE";

# Latents
	a [shape = circle];
	c [shape = circle];
	e [shape = circle];

# Manifests
	FC_rs [shape = square];

a -> FC_rs [dir = forward label="0.43"];
c -> FC_rs [dir = forward label="0.75"];
e -> FC_rs [dir = forward label="0.5"];{rank=same; FC_rs};
{rank=min; a};
{rank=max; c; e};

}